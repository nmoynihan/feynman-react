{
  "name": "@feynman/editor",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@feynman/core": "file:../feynman-core",
    "@feynman/react": "file:../feynman-react"
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json"
  }
}